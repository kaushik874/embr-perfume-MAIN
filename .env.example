# ============================================================
# Embr Perfume — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ──────────────────────────────────────────────────
PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret-at-least-64-chars
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ── PostgreSQL Database ──────────────────────────────────────
# Required. Use a Neon, Supabase, Railway or any PostgreSQL URL.
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@your_host/your_db?sslmode=require

# Optional: PostgreSQL connection pool settings
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=15000

# ── Razorpay Payments ────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com
# Use test keys for development, live keys for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret — set to match the secret in Razorpay Dashboard > Webhooks
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Google Sign-In ───────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ── SMTP (Optional) ─────────────────────────────────────────
# For sending OTP emails. Without this, OTPs show on screen in dev mode.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Embr Perfume <your-email@gmail.com>

# ── Automatic Backups ────────────────────────────────────────
# Set to "false" to disable automatic PostgreSQL JSON backups
# AUTO_DB_BACKUPS=true
# Backup interval in milliseconds (default: 6 hours)
# BACKUP_INTERVAL_MS=21600000
