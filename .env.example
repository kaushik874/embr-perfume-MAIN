# Google Sign-In — get from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Optional SMTP for OTP emails (otherwise code shows on login screen)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: SQLite path (default: data/embr.db)
# DATABASE_PATH=./data/embr.db

# Google Sign-In (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Optional SMTP for real OTP emails (otherwise OTP is shown on screen)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Embr Perfume <your-email@gmail.com>"
